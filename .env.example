# ============================================================
# Modelo de variaveis de ambiente do projeto.
# Copie este arquivo para .env e ajuste os valores:
#   Copy-Item .env.example .env
# O .env NAO e versionado (esta no .gitignore).
# ============================================================

# ----- Dados -----
RAW_DATA_PATH=data/raw/ratings.csv
PROCESSED_DATA_PATH=data/processed/interactions.parquet

# ----- MLflow -----
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=recomendador-ecommerce

# ----- Modelo -----
MODEL_TYPE=neural
EMBEDDING_DIM=32
LEARNING_RATE=0.001
EPOCHS=10
BATCH_SIZE=256

# ----- Reprodutibilidade -----
RANDOM_SEED=42
